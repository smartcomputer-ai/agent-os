{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aos.dev/air/v1/manifest.schema.json",
  "title": "AIR v1 manifest",
  "type": "object",
  "properties": {
    "$kind": { "const": "manifest" },
    "air_version": {
      "type": "string",
      "enum": ["1"],
      "description": "AIR format major version (string). Required; must be \"1\" for v1 manifests."
    },
    "schemas": {
      "type": "array",
      "items": { "$ref": "#/$defs/NamedRef" }
    },
    "modules": {
      "type": "array",
      "items": { "$ref": "#/$defs/NamedRef" }
    },
    "effects": {
      "type": "array",
      "items": { "$ref": "#/$defs/NamedRef" }
    },
    "effect_bindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/EffectBinding" }
    },
    "secrets": {
      "type": "array",
      "items": { "$ref": "#/$defs/NamedRef" }
    },
    "routing": {
      "type": "object",
      "properties": {
        "subscriptions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "event": { "$ref": "common.schema.json#/$defs/SchemaRef" },
              "module": { "$ref": "common.schema.json#/$defs/Name" },
              "key_field": { "type": "string", "description": "Field in event value that carries the cell key (for keyed workflows)" }
            },
            "required": ["event","module"],
            "additionalProperties": false
          }
        },
        "inboxes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source": { "type": "string", "description": "External inbox or adapter channel name (e.g., http.inbox:contact_form)" },
              "workflow": { "$ref": "common.schema.json#/$defs/Name", "description": "Workflow that will receive messages from this inbox; Name-formatted string" }
            },
            "required": ["source","workflow"],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["$kind","air_version","schemas","modules","effects"],
  "additionalProperties": false,
  "$defs": {
    "NamedRef": {
      "type": "object",
      "properties": {
        "name": { "$ref": "common.schema.json#/$defs/Name" },
        "hash": { "$ref": "common.schema.json#/$defs/Hash" }
      },
      "required": ["name","hash"],
      "additionalProperties": false
    },
    "EffectBinding": {
      "type": "object",
      "properties": {
        "kind": { "$ref": "common.schema.json#/$defs/EffectKind" },
        "adapter_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*(\\.[a-z0-9_.-]+)*$"
        }
      },
      "required": ["kind", "adapter_id"],
      "additionalProperties": false
    }
  }
}
